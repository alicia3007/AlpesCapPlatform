		{
			"name": "Solicitud exitosa - Servicio PASAJEROS",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test(\"Response has success flag\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"",
							"pm.test(\"Response contains service ID\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.idServicio).to.exist;",
							"    pm.environment.set(\"lastServiceId\", jsonData.idServicio);",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
